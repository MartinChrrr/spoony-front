{
  "cli": {
    "version": ">= 13.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "API_BASE_URL": "http://localhost:8080"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "API_BASE_URL": "https://api-staging.spoony.app"
      }
    },
    "production": {
      "env": {
        "API_BASE_URL": "https://api.spoony.app"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
